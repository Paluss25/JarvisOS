# ============================================================
# Jarvis .env.example — copy to .env and fill in values
# Variable names match K8s SealedSecrets where applicable.
# ============================================================

# --- OpenAI / Codex ---
OPENAI_MODEL=gpt-5.4
# Codex OAuth: auth token read from /root/.codex/auth.json (bind-mounted)

# --- Groq ---
GROQ_API_KEY=your-groq-api-key-here
# Note: existing ~/docker/.env uses GROK_API_KEY — config.py aliases both

# --- Anthropic ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Future providers (uncomment when available) ---
# GOOGLE_API_KEY=
# PERPLEXITY_API_KEY=

# --- LiteLLM proxy (optional — workers degrade gracefully if unset) ---
# LITELLM_API_KEY=    # K8s: litellm-api-key secret

# --- PostgreSQL ---
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://jarvis:change-me-strong-password@localhost:5432/jarvis

# --- Redis ---
REDIS_PASSWORD=change-me-strong-password
REDIS_URL=redis://:change-me-strong-password@localhost:6379/0

# --- Memory (memory-box HTTP API — set once the HTTP API is available) ---
MEMORY_BOX_URL=

# ============================================================
# CFO Finance Workers  (K8s: finance-agent-secrets)
# ============================================================
YNAB_API_KEY=your-ynab-personal-access-token   # K8s: finance-agent-secrets
YNAB_BUDGET_ID=last-used
BTC_FISCAL_API_URL=http://btc-fiscal-api:8080

# Bitpanda (crypto exchange)
BITPANDA_API_KEY=your-bitpanda-api-key

# Alpha Vantage (stock market data)
ALPHA_VANTAGE_KEY=your-alpha-vantage-key         # K8s: finance-agent-secrets

# Etherscan (on-chain ETH data)
ETHERSCAN_KEY=your-etherscan-api-key             # K8s: finance-agent-secrets

# Gestionale DB (local accounting DB — optional)
GESTIONALE_DB_URL=postgresql://user:pass@host:5432/gestionale  # K8s: finance-agent-secrets (GESTIONALE_DB_URL)

# ============================================================
# CFO Cost Workers
# ============================================================
PROMETHEUS_URL=http://prometheus:9090

# ============================================================
# CFO Market Workers  (K8s: finance-agent-secrets + polymarket-secrets)
# ============================================================
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_DATABASE_URL=postgresql://polymarket:change-me@postgres-shared:5432/polymarket  # K8s: finance-agent-secrets

# ============================================================
# CFO Shared: News
# ============================================================
NEWS_API_KEY=your-newsapi-org-key   # K8s: news-research-service secret

# --- Telegram ---
TELEGRAM_JARVIS_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_CHAT_ID=your-telegram-chat-id  # get from @userinfobot

# --- Workspace ---
WORKSPACE_PATH=/app/workspace

# --- Runtime ---
JARVIS_ENV=production
LOG_LEVEL=INFO
TZ=Europe/Rome
