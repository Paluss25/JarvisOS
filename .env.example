# ============================================================
# Jarvis .env.example — copy to .env and fill in values
# ============================================================

# --- OpenAI / Codex ---
OPENAI_MODEL=gpt-5.4
# Codex OAuth: auth token read from /root/.codex/auth.json (bind-mounted)

# --- Groq ---
GROQ_API_KEY=your-groq-api-key-here
# Note: existing ~/docker/.env uses GROK_API_KEY — config.py aliases both

# --- Future providers (uncomment when available) ---
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# PERPLEXITY_API_KEY=

# --- PostgreSQL ---
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://jarvis:change-me-strong-password@localhost:5432/jarvis

# --- Redis ---
REDIS_PASSWORD=change-me-strong-password
REDIS_URL=redis://:change-me-strong-password@localhost:6379/0

# --- Memory API ---
MEMORY_API_URL=https://memory-api.prova9x.com
MEMORY_API_USER_ID=jarvis

# --- Telegram ---
TELEGRAM_JARVIS_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_CHAT_ID=your-telegram-chat-id  # get from @userinfobot

# --- Workspace ---
WORKSPACE_PATH=/app/workspace

# --- Runtime ---
JARVIS_ENV=production
LOG_LEVEL=INFO
TZ=Europe/Rome
