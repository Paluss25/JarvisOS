{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "INPS extract extracted fields",
  "type": "object",
  "required": ["document_date"],
  "properties": {
    "document_date": {"type": "string", "format": "date"},
    "contribution_period": {"type": ["string", "null"]},
    "total_contributions": {"type": ["number", "null"]},
    "projected_pension_age": {"type": ["integer", "null"]},
    "projected_monthly_pension": {"type": ["number", "null"]}
  }
}
