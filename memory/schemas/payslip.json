{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Payslip extracted fields",
  "description": "Accepts both the legacy Telegram pipeline shape (period_from / period_to / net_pay) and the new HTTP API shape (month / year / net_amount) so that the same schema works for both code paths during the gestionale-chro migration.",
  "type": "object",
  "properties": {
    "month": {"type": ["integer", "null"], "minimum": 1, "maximum": 12},
    "year": {"type": ["integer", "null"]},
    "employer": {"type": ["string", "null"]},
    "employee_name": {"type": ["string", "null"]},
    "employee_code": {"type": ["string", "null"]},
    "gross_amount": {"type": ["number", "null"]},
    "net_amount": {"type": ["number", "null"]},
    "tax_amount": {"type": ["number", "null"]},
    "contribution_amount": {"type": ["number", "null"]},
    "extraction_confidence": {"type": ["number", "null"]},
    "extraction_metadata": {"type": ["object", "null"]},
    "notes": {"type": ["string", "null"]},
    "items": {"type": ["array", "null"]},
    "status": {"type": ["string", "null"]},
    "period_from": {"type": ["string", "null"], "format": "date"},
    "period_to": {"type": ["string", "null"], "format": "date"},
    "gross_pay": {"type": ["number", "null"]},
    "net_pay": {"type": ["number", "null"]},
    "inps_employee": {"type": ["number", "null"]},
    "irpef_withheld": {"type": ["number", "null"]},
    "tfr_accrued": {"type": ["number", "null"]},
    "leave_residual_days": {"type": ["number", "null"]},
    "rol_residual_hours": {"type": ["number", "null"]}
  }
}
